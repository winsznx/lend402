{
  "name": "lend402-dashboard",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "description": "Stacks-native x402 payment and credit rail for agentic APIs",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "next lint",
    "clarinet:check": "clarinet check -m Clarinet.toml",
    "clarinet:format": "clarinet format contracts/lend402-vault.clar",
    "clarinet:console:mainnet": "clarinet console -m Clarinet.toml --enable-remote-data",
    "test:e2e": "vitest run tests/e2e"
  },
  "dependencies": {
    "@stacks/connect": "^7.10.1",
    "@stacks/encryption": "^6.17.0",
    "@stacks/network": "^6.13.0",
    "@stacks/transactions": "^6.16.0",
    "@winsznx/lend402": "^0.1.2",
    "axios": "^1.7.7",
    "ioredis": "^5.10.0",
    "next": "^16.1.6",
    "postgres": "^3.4.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "uuid": "^10.0.0",
    "x402-stacks": "^2.0.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.4",
    "@types/node": "^20",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.3",
    "eslint-config-next": "^16.1.6",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vitest": "^4.1.0"
  },
  "workspaces": [
    "packages/*"
  ]
