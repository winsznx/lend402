# =============================================================================
# Lend402 — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# =============================================================================

# ----------------------------------------------------------------------------
# Agent Wallet (required for /api/trigger-agent SSE route)
# The agent that holds sBTC collateral and signs borrow-and-pay transactions.
# ----------------------------------------------------------------------------

# Hex-encoded secp256k1 private key — NO 0x prefix
LEND402_AGENT_PRIVATE_KEY=your_hex_private_key_here

# Stacks address corresponding to LEND402_AGENT_PRIVATE_KEY
LEND402_AGENT_ADDRESS=ST1PQHQKV0RJXZFY1DGX8MNSNYVE3VGZJSRTPGZGM

# ----------------------------------------------------------------------------
# Network
# ----------------------------------------------------------------------------

# "testnet" | "mainnet"  — controls which Stacks node + contract address is used
STACKS_NETWORK=testnet

# ----------------------------------------------------------------------------
# Merchant API
# URL of the running merchant-api server (server/merchant-api.ts)
# Default: http://localhost:3001
# ----------------------------------------------------------------------------

MERCHANT_API_URL=http://localhost:3001

# ----------------------------------------------------------------------------
# Merchant API Secret (used by merchant-api.ts server only)
# Shared secret between the Next.js API route and the merchant server for
# the Facilitator to authenticate broadcast requests.
# ----------------------------------------------------------------------------

MERCHANT_API_SECRET=change_me_in_production
