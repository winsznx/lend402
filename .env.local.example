# =============================================================================
# Lend402 — mainnet-first environment template
# Copy this file to .env.local and fill in your values.
# =============================================================================

# -----------------------------------------------------------------------------
# Stacks network
# Set both server and client values together.
# Use "testnet" only when explicitly validating against Stacks testnet.
# -----------------------------------------------------------------------------

STACKS_NETWORK=mainnet
NEXT_PUBLIC_STACKS_NETWORK=mainnet

# -----------------------------------------------------------------------------
# Agent wallet
# Used by /api/trigger-agent for the end-to-end agent demo flow.
# -----------------------------------------------------------------------------

LEND402_AGENT_PRIVATE_KEY=your_hex_private_key_here
LEND402_AGENT_ADDRESS=SP1YOURAGENTADDRESS
NEXT_PUBLIC_LEND402_AGENT_ADDRESS=SP1YOURAGENTADDRESS

# -----------------------------------------------------------------------------
# Contract configuration
# LEND402_VAULT_CONTRACT_ID is required.
# sBTC and USDCx default to the canonical Stacks contracts in src/lib/network.ts.
# -----------------------------------------------------------------------------

LEND402_VAULT_CONTRACT_ID=SPXXXX.lend402-vault-v3
NEXT_PUBLIC_LEND402_VAULT_CONTRACT_ID=SPXXXX.lend402-vault-v3

# Optional explicit overrides
# LEND402_SBTC_CONTRACT_ID=SM3VDXK3WZZSA84XXFKAFAF15NNZX32CTSG82JFQ4.sbtc-token
# LEND402_USDCX_CONTRACT_ID=SP120SBRBQJ00MCWS7TM5R8WJNTTKD5K0HFRC2CNE.usdcx

# -----------------------------------------------------------------------------
# Optional refresh-price-cache relayer
# Use a dedicated low-balance wallet for the internal cache warmer route.
# PRICE_CACHE_REFRESH_SECRET can be the same value as CRON_SECRET if you use
# a scheduler that sends Authorization: Bearer <secret>.
# -----------------------------------------------------------------------------

# LEND402_CACHE_REFRESH_PRIVATE_KEY=your_hex_private_key_here
# PRICE_CACHE_REFRESH_SECRET=replace_with_random_secret
# CRON_SECRET=replace_with_random_secret

# -----------------------------------------------------------------------------
# Railway Postgres + Railway Redis
# Railway Postgres exposes DATABASE_URL plus PGHOST/PGPORT/PGUSER/PGPASSWORD/PGDATABASE.
# Railway Redis exposes REDIS_URL plus REDISHOST/REDISPORT/REDISUSER/REDISPASSWORD.
# If your app service also runs on Railway, reference them as:
# DATABASE_URL=${{Postgres.DATABASE_URL}}
# REDIS_URL=${{Redis.REDIS_URL}}
# -----------------------------------------------------------------------------

DATABASE_URL=postgresql://postgres:password@127.0.0.1:5432/lend402
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Gateway URLs
# DEFAULT_VAULT_URL powers the demo agent flow when no targetUrl is provided.
# NEXT_PUBLIC_GATEWAY_BASE_URL is used when rendering wrapped URLs in the UI.
# -----------------------------------------------------------------------------

# DEFAULT_VAULT_URL is optional. Leave it unset until you have a real vault URL.
# DEFAULT_VAULT_URL=https://lend402.xyz/v/your-vault-id/
NEXT_PUBLIC_GATEWAY_BASE_URL=https://lend402.xyz
NEXT_PUBLIC_HIRO_EXPLORER_BASE_URL=https://explorer.hiro.so
